# Qwen3-TTS Streaming Server Configuration
# Copy to .env and adjust as needed

# Model (Base = voice cloning + true streaming, CustomVoice = named speakers)
TTS_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-1.7B-Base
TTS_DEVICE=cuda:0

# Voice clone reference (Base model only)
TTS_REF_AUDIO_PATH=audio.mp3
TTS_REF_TEXT=In the quiet hours before dawn, when the city still slept beneath a blanket of fog, a single lighthouse beam swept across the harbor — steady, patient, unwavering.

# Server
TTS_HOST=0.0.0.0
TTS_PORT=8153

# Auth (leave empty to disable)
TTS_API_KEY=

# Queue / Limits
TTS_MAX_QUEUE_SIZE=50
TTS_REQUEST_TIMEOUT=120

# Defaults
TTS_DEFAULT_VOICE=Aiden
TTS_DEFAULT_LANGUAGE=English

# CORS
TTS_CORS_ORIGINS=["*"]

# Logging
TTS_LOG_LEVEL=INFO

# Streaming
TTS_EMIT_EVERY_FRAMES=4
TTS_DECODE_WINDOW_FRAMES=80

# Optimizations
TTS_ENABLE_COMPILE=true
TTS_WARMUP_ON_START=true
